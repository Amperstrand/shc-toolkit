#!/bin/bash
# NoDNS certbot auth hook — publishes _acme-challenge TXT via Nostr kind 11111
set -e

source /opt/nodns-venv/bin/activate

python3 -c "
import sys, time, json
from nostr_sdk import Keys, Client, EventBuilder, Tag, Timestamp

NSEC_FILE = '{{ certbot_nsec_path }}'
ZONE = '{{ nodns_zone }}'
DOMAIN = '${CERTBOT_DOMAIN}'
VALIDATION = '${CERTBOT_VALIDATION}'

with open(NSEC_FILE) as f:
    nsec_hex = f.read().strip()

if nsec_hex.startswith('nsec1'):
    keys = Keys.from_bech32(nsec_hex)
else:
    keys = Keys.from_hex(nsec_hex)

client = Client()
client.add_relay('wss://nos.lol')
client.add_relay('wss://relay.nodns.shop')
client.connect()

record = json.dumps([{
    'type': 'TXT',
    'name': '_acme-challenge',
    'value': VALIDATION,
    'ttl': 120,
}])

event = EventBuilder(
    kind=11111,
    content=record,
    tags=[
        Tag.identifier(DOMAIN),
        Tag.custom('t', 'dns'),
        Tag.custom('zone', ZONE),
    ],
).sign_with_keys(keys)

client.send_event(event)
print(f'Published _acme-challenge TXT for {DOMAIN}', file=sys.stderr)

time.sleep(15)
"

echo "NoDNS auth hook complete" >&2
